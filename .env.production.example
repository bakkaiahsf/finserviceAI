# Production Environment Variables for Vercel
# Copy these to your Vercel Dashboard Environment Variables

# Application Configuration - UPDATE THIS TO YOUR VERCEL URL
NEXT_PUBLIC_APP_URL=https://finservice-6amye4prc-bakkaiahs-projects.vercel.app
NEXT_PUBLIC_APP_NAME="Nexus AI"
NEXT_PUBLIC_APP_DESCRIPTION="AI-Powered Corporate Intelligence Platform"

# Supabase Configuration - Use your actual Supabase project values
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# DeepSeek AI API - Use your actual API key
DEEPSEEK_API_KEY=your_deepseek_api_key

# External Data APIs - Use your actual API keys
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key
OPENCORPORATES_API_KEY=your_opencorporates_api_key

# Google OAuth (for Supabase Auth) - Use your actual values from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-endpoint-secret

# Optional: Analytics & Monitoring
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id
SENTRY_DSN=your_sentry_dsn

# Optional: Email Service (for notifications)
RESEND_API_KEY=your_resend_api_key
SMTP_FROM=noreply@yourdomain.com